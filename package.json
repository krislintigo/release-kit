{
  "name": "@krislintigo/release-kit",
  "version": "1.1.0",
  "description": "Opinionated release toolkit: a shareable semantic-release config, commitlint/husky/publint helpers, and a CLI to release and scaffold npm packages.",
  "type": "module",
  "license": "MIT",
  "author": "krislintigo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krislintigo/release-kit.git"
  },
  "homepage": "https://github.com/krislintigo/release-kit#readme",
  "bugs": {
    "url": "https://github.com/krislintigo/release-kit/issues"
  },
  "packageManager": "pnpm@10.7.0",
  "engines": {
    "node": ">=24.16.0"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "release-kit": "./src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./config": {
      "types": "./src/index.d.ts",
      "default": "./src/config.js"
    },
    "./commitlint": {
      "types": "./src/commitlint.d.ts",
      "default": "./src/commitlint.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./src/index.d.ts",
  "scripts": {
    "check": "node --check src/cli.js && node src/cli.js check --self",
    "commitlint": "commitlint",
    "prepare": "husky",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "semantic-release",
    "semantic-release-config",
    "release",
    "changelog",
    "conventional-commits",
    "commitlint",
    "husky",
    "publint",
    "npm",
    "release-config"
  ],
  "peerDependencies": {
    "@commitlint/cli": ">=21",
    "husky": ">=9",
    "semantic-release": ">=25"
  },
  "dependencies": {
    "@commitlint/config-conventional": "^21.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "conventional-changelog-conventionalcommits": "^10.2.0",
    "publint": "^0.3.21"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.5"
  }
}
